{
  "definition": {
    "document": {
      "dsl": "1.0.0",
      "name": "stability_sheets_export",
      "version": "1.0",
      "namespace": "base44"
    },
    "do": [
      {
        "export_stability": {
          "call": "invoke_backend_function",
          "with": {
            "function_name": "stabilitySheetsExport",
            "args": {}
          },
          "then": "end",
          "x-base44": {
            "title": "Export stability logs to Google Sheets",
            "description": "Settlement alerts + Aegis anomalies + healing events"
          }
        }
      }
    ]
  },
  "name": "Stability Sheets Export",
  "trigger": {
    "condition": null,
    "config": {
      "trigger_type": "scheduled",
      "events": [],
      "schedule_mode": "recurring",
      "cron_expression": "0 * * * *",
      "one_time_date": null,
      "timezone": "America/Chicago",
      "interval_value": null,
      "interval_unit": null,
      "interval_anchor": null,
      "ends_type": "never",
      "ends_on_date": null,
      "ends_after_count": null
    }
  },
  "description": "Automatically exports settlement anomalies, Aegis infrastructure anomalies, and healing/repair events to a Google Sheet every hour for long-term platform stability tracking"
}