{
  "definition": {
    "document": {
      "dsl": "1.0.0",
      "name": "optimization_event_export",
      "version": "1.1",
      "namespace": "base44"
    },
    "do": [
      {
        "export_on_proposal": {
          "call": "invoke_backend_function",
          "with": {
            "function_name": "stabilitySheetsExport",
            "args": {}
          },
          "then": "mark_exported",
          "x-base44": {
            "title": "Export to Google Sheets on new Arete proposal",
            "description": "Pushes new optimization proposal + any pending stability logs"
          }
        }
      },
      {
        "mark_exported": {
          "call": "invoke_backend_function",
          "with": {
            "function_name": "markOptimizationExported",
            "args": {
              "entity_id": "${ .trigger.entity_id }"
            }
          },
          "then": "end",
          "x-base44": {
            "title": "Mark proposal as exported",
            "description": "Sets OptimizationEvent status to exported"
          }
        }
      }
    ]
  },
  "name": "Arete Optimization Export",
  "trigger": {
    "condition": null,
    "config": {
      "trigger_type": "entity",
      "entity_name": "OptimizationEvent",
      "events": [
        "create"
      ]
    }
  },
  "description": "Triggers a Google Sheets stability export whenever a new Arete optimization proposal is logged, then marks the proposal as exported"
}